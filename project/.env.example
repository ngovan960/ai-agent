# Database
DATABASE_URL=postgresql+asyncpg://ai_sdlc_user:dev_password@localhost:5432/ai_sdlc
DATABASE_URL_SYNC=postgresql://ai_sdlc_user:dev_password@localhost:5432/ai_sdlc

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change_this_to_a_secure_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Providers (LiteLLM)
LITELLM_API_KEY=
LITELLM_MODEL=deepseek/deepseek-chat

# App Settings
APP_NAME=AI SDLC Orchestrator
DEBUG=true
LOG_LEVEL=info
ENVIRONMENT=development

# OpenCode Adapter
OPENCODE_ENABLED=true
OPENCODE_SANDBOX_IMAGE=ai-sdlc-sandbox:latest
